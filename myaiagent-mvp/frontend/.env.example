# API Configuration
# For local development:
VITE_API_URL=http://localhost:3000/api
# For production (Cloudflare Pages), set this variable to your Railway URL:
# VITE_API_URL=https://myaiagent-production.up.railway.app/api
# Enhanced Features
# Set to 'false' to disable WebSocket streaming and Voice Activity Detection for STT
# Default: true (enabled)
VITE_ENABLE_ENHANCED_STT=true
